   "paths":{
      "/egress/aggregated/[<Queue Index>/]default":{
         "get":{
            "tags":[
               "Aggregated Egress Queue"
            ],
            "summary":"Set the default policy for the aggregated egress queue",
            "description":"Set the policy to be applied by default to the traffic directed to the aggregated egress queue or interface.",
            "operationId":"egress_aggregated_default",
            "produces":[
               "application/json"
            ],
            "parameters":[
               {
                  "name":"action",
                  "in":"query",
                  "description":"Default action (forward, discard, shunt, slice-l4, slice-l3)",
                  "required":true,
                  "type":"string"
               }
            ],
            "responses":{
               "200":{
                  "description":"Successful operation, the returned object contains the actual status.",
                  "schema":{
                     "$ref":"#/definitions/Status"
                  }
               },
               "400":{
                  "description":"Invalid status value."
               }
            }
         }
      },
      "/egress/aggregated/[<Queue Index>/]ip":{
         "get":{
            "tags":[
               "Aggregated Egress Queue"
            ],
            "summary":"Set a subnet-based policy for the aggregated egress queue",
            "description":"Set a policy to be applied to all traffic matching the provided subnet and directed to the aggregated egress queue or interface.",
            "operationId":"egress_aggregated_default",
            "produces":[
               "application/json"
            ],
            "parameters":[
               {
                  "name":"subnet",
                  "in":"query",
                  "description":"Subnet to match in CIDR format",
                  "required":true,
                  "type":"string"
               },
               {
                  "name":"action",
                  "in":"query",
                  "description":"Action (forward, discard, shunt, slice-l4, slice-l3)",
                  "required":true,
                  "type":"string"
               }
            ],
            "responses":{
               "200":{
                  "description":"Successful operation, the returned object contains the actual status.",
                  "schema":{
                     "$ref":"#/definitions/Status"
                  }
               },
               "400":{
                  "description":"Invalid status value."
               }
            }
         }
      },
      "/egress/aggregated/[<Queue Index>/]protocol/<Application Protocol>":{
         "get":{
            "tags":[
               "Aggregated Egress Queue"
            ],
            "summary":"Set a layer-7 protocol-based policy for the aggregated egress queue",
            "description":"Set a policy to be applied to all traffic matching the provided layer-7 application protocol (nDPI) and directed to the aggregated egress queue or interface.",
            "operationId":"egress_aggregated_default",
            "produces":[
               "application/json"
            ],
            "parameters":[
